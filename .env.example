# Bybit API (Testnet by default)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true
BYBIT_BASE_URL=https://api-testnet.bybit.com

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_ID=        # Твій Telegram User ID (дізнатись через @userinfobot)

# Dashboard auth
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD_HASH=
JWT_SECRET=change-me-to-a-long-random-string
SESSION_TTL_HOURS=24

# Trading
INITIAL_BALANCE=10000
MAX_DAILY_LOSS_PCT=3.0
MAX_POSITION_PCT=5.0
DEFAULT_LEVERAGE=5
TRADING_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT
MIN_CONFIDENCE=0.62         # Мінімальна впевненість для входу
TAKE_PROFIT_PCT=1.5
STOP_LOSS_PCT=0.8

# Security
ENV_ENCRYPTION_KEY=
FORCE_HTTPS=true
RATE_LIMIT=60/minute

# Runtime
LOG_LEVEL=INFO
TIMEZONE=Europe/Kyiv
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# Brain FILE snapshots only (disk hygiene). Experience/mistakes are NEVER deleted.
MODEL_KEEP_VERSIONS=1
EXPERIENCE_MAX_SAMPLES=50000
CONTINUAL_LEARNING=true

# Feature flags (Part 9)
SCAN_INTERVAL_SECONDS=60    # Як часто сканувати ринок
GRID_ENABLED=false          # Grid Trading увімкнений
FUNDING_ENABLED=false       # Funding Rate Harvesting
TOURNAMENT_ENABLED=false    # Tournament Mode
COMPOUND_ENABLED=true       # Складний відсоток
SHADOW_MODE=true            # Тіньовий портфель
